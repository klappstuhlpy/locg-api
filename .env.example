# Port the API listens on
PORT=8070

# FlareSolverr instance used to clear Cloudflare. With docker-compose this is the
# service name; for a local run it's typically http://localhost:8191
FLARESOLVERR_URL=http://flaresolverr:8191

# Per-request FlareSolverr timeout, in milliseconds
FLARESOLVERR_TIMEOUT=60000

# How long to cache a comic's scraped detail page, in hours (168 = 7 days)
DETAIL_TTL_HOURS=168

# Max number of detail pages scraped in parallel
DETAIL_CONCURRENCY=2
